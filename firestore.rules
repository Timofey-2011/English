rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['onboardingComplete', 'estimatedIELTSBand', 'masteryScores'])
        && data.onboardingComplete is bool
        && data.estimatedIELTSBand is number
        && data.masteryScores is map
        && (data.updatedAt == request.time || !data.keys().hasAll(['updatedAt']))
        && (!data.keys().hasAll(['streak']) || data.streak is map)
        && (!data.keys().hasAll(['achievements']) || data.achievements is list)
        && data.masteryScores.keys().hasAll(['speaking', 'writing', 'listening', 'reading', 'grammar', 'vocabulary'])
        && data.masteryScores.speaking is number
        && data.masteryScores.writing is number
        && data.masteryScores.listening is number
        && data.masteryScores.reading is number
        && data.masteryScores.grammar is number
        && data.masteryScores.vocabulary is number;
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['taskId', 'score', 'feedback', 'date', 'taskType'])
        && data.taskId is string && data.taskId.size() <= 128
        && data.score is number && data.score >= 0 && data.score <= 100
        && data.feedback is string && data.feedback.size() <= 5000
        && data.date is string
        && data.taskType is string
        && (data.timestamp == request.time || !data.keys().hasAll(['timestamp']));
    }

    // --- Navigation Rules ---
    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      match /history/{historyId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(historyId) && isValidHistoryItem(incoming());
        // History items are typically immutable in this app
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
